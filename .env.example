# === Supabase ===
# Ambil dari Project Settings > API di dashboard Supabase kamu
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=isi-anon-key-di-sini

# Service role key HANYA dipakai di server (server actions/seed script).
# JANGAN PERNAH expose ke client / commit ke git.
SUPABASE_SERVICE_ROLE_KEY=isi-service-role-key-di-sini

# === QR Attendance ===
# Secret untuk menandatangani token QR harian (HMAC). Bebas string acak & panjang.
QR_SIGNING_SECRET=ganti-dengan-string-acak-minimal-32-karakter

# Radius toleransi absensi (opsional, dipakai jika ingin validasi lokasi di masa depan)
NEXT_PUBLIC_APP_NAME="Politeknik SSR"
